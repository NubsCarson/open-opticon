[37.583, "o", "# 6) Tier 3 \u2014 open the enclosure lid: the enclave refuses to attest\r\n"]
[38.0, "o", "$ he_host /usr/bin/clip.pcm $NONCE        \u001b[90m# healthy device\u001b[0m\r\n"]
[38.083, "o", "  \u001b[1;32msigned bound output\u001b[0m \u001b[90m(event=alarm_tone, counter=1)  ->  he-verify PASS\u001b[0m\r\n"]
[38.167, "o", "\r\n"]
[38.25, "o", "$ he_host --trip                          \u001b[90m# someone opens the enclosure lid\u001b[0m\r\n"]
[38.333, "o", "tamper flag latched; device will refuse attestation\r\n"]
[38.417, "o", "\r\n"]
[38.5, "o", "$ he_host /usr/bin/clip.pcm $NONCE        \u001b[90m# same firmware, same key, same clip\u001b[0m\r\n"]
[38.583, "o", "he_host: attest_audio: \u001b[1;31m0xffff000f\u001b[0m  \u001b[90m(TEE_ERROR_SECURITY)\u001b[0m\r\n"]
[38.667, "o", "\u001b[1;31mFAIL\u001b[0m  the enclave refuses to attest a tampered device\r\n"]
