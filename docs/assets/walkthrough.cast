[4.25, "o", "# 2) a REAL OP-TEE attestation on Arm TrustZone (QEMU) \u2014 Veraison's verdict\r\n"]
[4.667, "o", "optee_remote_attestation        \u001b[90m# in the guest TEE, as root\u001b[0m\r\n"]
[4.75, "o", "  \u001b[90mPSA/COSE attestation token  ->  Veraison verifier\u001b[0m\r\n"]
